{
    "$schema": "https://raw.githubusercontent.com/EmmyLuaLs/emmylua-analyzer-rust/refs/heads/main/crates/emmylua_code_analysis/resources/schema.json",
    "diagnostics": {
        "disable": ["unnecessary-if"]
    },
    "workspace": {
        "workspaceRoots": ["just_another_shop_mod"],
        "ignoreDir": [".git", "node_modules", ".tmp", "jasm_test"],
        "ignoreGlobs": ["lua/**", "**/submodule/**"],
        "library": [".libraries", ".types"]
    },
    "runtime": {
        "requirePattern": [
            "?/?/42/media/lua/shared/?.lua",
            "?/?/42/media/lua/client/?.lua",
            "?/?/42/media/lua/server/?.lua"
        ],
        "version": "Lua5.1"
    }
}
